' PACKAGE: DECORATOR PATTERN - CONTENT ACCESS
' ============================================================
package "Decorator Pattern - Content Access" #FCE4EC {

  interface ContentAccessor {
    + getContent(id: UUID): Object
  }

  class BaseContentAccessor {
    --
    + getContent(id: UUID): Object
  }

  abstract class ContentAccessDecorator {
    # wrapped: ContentAccessor
    --
    + getContent(id: UUID): Object
  }

  class VisibilityCheckDecorator {
    - visibilityStrategy: VisibilityStrategy
    - fan: Fan
    --
    + getContent(id: UUID): Object
  }

  class AuditAccessDecorator {
    - auditService: AuditService
    --
    + getContent(id: UUID): Object
  }

  class CacheDecorator {
    - cache: Map<UUID, Object>
    - ttlSeconds: int
    --
    + getContent(id: UUID): Object
    + invalidate(id: UUID): void
  }

  BaseContentAccessor ..|> ContentAccessor
  ContentAccessDecorator ..|> ContentAccessor
  ContentAccessDecorator o--> ContentAccessor
  VisibilityCheckDecorator --|> ContentAccessDecorator
  AuditAccessDecorator --|> ContentAccessDecorator
  CacheDecorator --|> ContentAccessDecorator
  VisibilityCheckDecorator --> VisibilityStrategy
}

