package "Repository Pattern - Tenant Scoped" #F9FBE7 {

  abstract class TenantAwareRepository {
    # tenantId: UUID
    --
    + findById(id: UUID): Object
    + findAll(filters: Map): List
    + save(entity: Object): Object
    + delete(id: UUID): void
    # applyTenantFilter(query): Query
  }

  class BlogPostRepository {
    --
    + findById(id: UUID): BlogPost
    + findAll(filters: Map): List<BlogPost>
    + findByCategory(categoryId): List<BlogPost>
    + findByVisibility(v): List<BlogPost>
    + save(post: BlogPost): BlogPost
    + delete(id: UUID): void
  }

  class MerchProductRepository {
    --
    + findById(id: UUID): MerchProduct
    + findAll(filters: Map): List<MerchProduct>
    + findByCategory(categoryId): List<MerchProduct>
    + findAvailable(): List<MerchProduct>
    + save(product: MerchProduct): MerchProduct
    + delete(id: UUID): void
  }

  class MerchOrderRepository {
    --
    + findById(id: UUID): MerchOrder
    + findAll(filters: Map): List<MerchOrder>
    + findByFan(fanId: UUID): List<MerchOrder>
    + findByStatus(status): List<MerchOrder>
    + save(order: MerchOrder): MerchOrder
    + delete(id: UUID): void
  }

  class FanRepository {
    --
    + findById(id: UUID): Fan
    + findAll(filters: Map): List<Fan>
    + findByEmail(email: String): Fan
    + save(fan: Fan): Fan
    + delete(id: UUID): void
  }

  class FanSubscriptionRepository {
    --
    + findById(id: UUID): FanSubscription
    + findAll(filters: Map): List<FanSubscription>
    + findByFan(fanId: UUID): List<FanSubscription>
    + findExpiring(days: int): List<FanSubscription>
    + save(sub: FanSubscription): FanSubscription
    + delete(id: UUID): void
  }

  class IdolProfileRepository {
    --
    + findById(id: UUID): IdolProfile
    + findAll(filters: Map): List<IdolProfile>
    + findByGroup(groupId): List<IdolProfile>
    + save(idol: IdolProfile): IdolProfile
    + delete(id: UUID): void
  }

  BlogPostRepository --|> TenantAwareRepository
  MerchProductRepository --|> TenantAwareRepository
  MerchOrderRepository --|> TenantAwareRepository
  FanRepository --|> TenantAwareRepository
  FanSubscriptionRepository --|> TenantAwareRepository
  IdolProfileRepository --|> TenantAwareRepository
}

