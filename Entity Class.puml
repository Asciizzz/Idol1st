    + getSubtotal(): Decimal
    + updateQuantity(qty): void
  }

  class MerchOrder {
    - id: UUID
    - tenantId: UUID
    - fanId: UUID
    - totalAmount: Decimal
    - currency: String
    - status: OrderStatus
    - placedAt: DateTime
    --
    + getState(): OrderState
    + confirm(): void
    + cancel(): void
    + getItems(): List<MerchOrderItem>
  }

  class MerchOrderItem {
    - id: UUID
    - orderId: UUID
    - productId: UUID
    - variantId: UUID
    - quantity: Integer
