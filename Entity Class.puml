    --
    + setAsDefault(): void
    + format(): String
  }

  class Payment {
    - id: UUID
    - orderId: UUID
    - tenantId: UUID
    - amount: Decimal
    - currency: String
    - status: PaymentStatus
    - method: PaymentMethod
    - transactionId: String
    - paidAt: DateTime
    --
    + isSuccessful(): Boolean
    + refund(): void
  }

  class Shipment {
    - id: UUID
    - orderId: UUID
    - trackingNumber: String
    - carrier: String
    - status: ShipmentStatus
    - shippedAt: DateTime
    - estimatedDelivery: DateTime
