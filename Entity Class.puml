    + getAvailableQty(): Integer
    + reserve(qty): void
    + release(qty): void
  }

  class MerchCart {
    - id: UUID
    - tenantId: UUID
    - fanId: UUID
    - createdAt: DateTime
    - updatedAt: DateTime
    --
    + addItem(productId, variantId, qty): void
    + removeItem(itemId): void
