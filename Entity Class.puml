package "Strategy Pattern - Payment" #FFFDE7 {

  class PaymentContext {
    - strategy: PaymentStrategy
    - order: MerchOrder
    --
    + setStrategy(s: PaymentStrategy): void
    + processPayment(): Payment
    + refund(paymentId): void
  }

  interface PaymentStrategy {
    + processPayment(amount, currency): Payment
    + refund(paymentId): void
    + validate(): Boolean
  }

  class CreditCardStrategy {
    - cardNumber: String
    - expiryDate: String
    - cvv: String
    --
    + processPayment(amount, currency): Payment
    + refund(paymentId): void
    + validate(): Boolean
  }

  class PayPalStrategy {
    - paypalEmail: String
    - accessToken: String
    --
    + processPayment(amount, currency): Payment
    + refund(paymentId): void
    + validate(): Boolean
  }

  class StripeStrategy {
    - stripeToken: String
    - customerId: String
    --
    + processPayment(amount, currency): Payment
    + refund(paymentId): void
    + validate(): Boolean
  }

  PaymentContext --> PaymentStrategy
  PaymentContext --> MerchOrder
  CreditCardStrategy ..|> PaymentStrategy
  PayPalStrategy ..|> PaymentStrategy
  StripeStrategy ..|> PaymentStrategy
}

