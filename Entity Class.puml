@startuml Idol_SaaS_Full_System
' ============================================================
' IDOL SAAS PLATFORM - FULL CLASS DIAGRAM
' Layers: Platform Admin | Tenant/Idol | Fan Domain
' Patterns: Command, Facade, Strategy, Decorator,
'           Chain of Responsibility, Observer, State,
'           Repository
' ============================================================

!theme plain
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam packageFontStyle bold
skinparam packageBorderColor #555555
skinparam packageBackgroundColor #FAFAFA
skinparam ArrowColor #444444
skinparam classBorderColor #444444
skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #444444
  HeaderBackgroundColor #E8EAF6
}

' ============================================================
' ============================================================
' SECTION 1: PLATFORM ADMIN LAYER
' ============================================================
' ============================================================

' ============================================================
' PACKAGE: PLATFORM IDENTITY LAYER
' ============================================================
package "Platform Identity Layer" #EDE7F6 {

  class ServiceAdmin {
    - id: UUID
    - email: String
    - passwordHash: String
    - role: AdminRole
    - permissions: List<AdminPermission>
    - mfaEnabled: Boolean
    - lastLoginAt: DateTime
    - createdAt: DateTime
    - isActive: Boolean
    --
    + getId(): UUID
    + getRole(): AdminRole
    + getPermissions(): List<AdminPermission>
    + isMfaEnabled(): Boolean
  }

  enum AdminRole {
    SUPER_ADMIN
    SUPPORT
    BILLING_ADMIN
    OPS
  }

  enum AdminPermission {
    MANAGE_TENANTS
    MANAGE_PLANS
    MANAGE_FEATURES
    VIEW_AUDIT_LOGS
    IMPERSONATE
    SYSTEM_CONFIG
  }

  class TenantAdmin {
    - id: UUID
    - tenantId: UUID
    - email: String
    - passwordHash: String
    - role: TenantRole
    - permissions: List<TenantPermission>
    - lastLoginAt: DateTime
    - createdAt: DateTime
    - isActive: Boolean
    --
    + getId(): UUID
    + getTenantId(): UUID
    + getRole(): TenantRole
  }

  enum TenantRole {
    OWNER
    ADMIN
    BILLING
  }

  class User {
    - id: UUID
    - email: String
    - passwordHash: String
    - createdAt: DateTime
    - isActive: Boolean
    --
    + getId(): UUID
    + getEmail(): String
  }

  ServiceAdmin --> AdminRole
  ServiceAdmin --> AdminPermission
  TenantAdmin --> TenantRole
  TenantAdmin --|> User
}

' ============================================================
' PACKAGE: TENANT DOMAIN LAYER
' ============================================================
package "Tenant Domain Layer" #E8F5E9 {

  class Tenant {
    - id: UUID
    - name: String
    - status: TenantStatus
    - createdBy: UUID
    - createdAt: DateTime
    - suspendedAt: DateTime
    - deletedAt: DateTime
    --
    + getId(): UUID
    + getName(): String
    + getStatus(): TenantStatus
    + isActive(): Boolean
  }

  enum TenantStatus {
    ACTIVE
    SUSPENDED
    DELETED
    PENDING
  }

  class TenantConfig {
    - id: UUID
    - tenantId: UUID
    - brandingLogo: String
    - brandingColors: String
    - customDomain: String
    - settings: Map<String, Object>
    --
    + getSetting(key): Object
    + updateSetting(key, val): void
  }

  class TenantMembership {
    - id: UUID
    - tenantId: UUID
    - userId: UUID
    - roleId: UUID
    - joinedAt: DateTime
    - isActive: Boolean
    --
    + getRole(): Role
    + deactivate(): void
  }

  class Role {
    - id: UUID
    - tenantId: UUID
    - name: String
    - permissions: List<TenantPermission>
    --
    + hasPermission(p): Boolean
    + addPermission(p): void
  }

  class TenantSubscription {
    - id: UUID
    - tenantId: UUID
    - planId: UUID
    - startDate: DateTime
    - endDate: DateTime
    - status: SubscriptionStatus
    --
    + isActive(): Boolean
    + getPlan(): Plan
  }

  class Plan {
    - id: UUID
    - name: String
    - price: Decimal
    - billingCycle: BillingCycle
    - features: List<Feature>
    --
    + getFeatures(): List<Feature>
    + hasFeature(f): Boolean
  }

  class Feature {
    - id: UUID
    - name: String
    - description: String
    - isEnabled: Boolean
    --
    + enable(): void
    + disable(): void
  }

  class FeatureFlag {
    - id: UUID
    - name: String
    - isGloballyEnabled: Boolean
    - createdAt: DateTime
    --
    + isEnabled(): Boolean
    + rolloutGlobally(): void
  }

  class TenantFeatureOverride {
    - id: UUID
    - tenantId: UUID
    - flagId: UUID
    - isEnabled: Boolean
    - overriddenAt: DateTime
    --
    + apply(): void
    + revert(): void
  }

  class AuditLog {
    - id: UUID
    - tenantId: UUID
    - adminId: UUID
    - action: String
    - targetEntity: String
    - targetId: UUID
    - metadata: Map<String, Object>
    - performedAt: DateTime
    --
    + getDetails(): String
  }

  class SystemConfig {
    - id: UUID
    - key: String
    - value: Object
    - updatedBy: UUID
    - updatedAt: DateTime
    --
    + getValue(): Object
    + setValue(val): void
  }

  class ImpersonationSession {
    - id: UUID
    - adminId: UUID
    - targetTenantId: UUID
    - targetUserId: UUID
    - startedAt: DateTime
    - expiresAt: DateTime
    - isActive: Boolean
    --
    + start(): void
    + end(): void
    + isExpired(): Boolean
  }

  Tenant --> TenantStatus
  Tenant "1" *-- "1" TenantConfig
  Tenant "1" *-- "many" TenantMembership
  Tenant "1" *-- "1" TenantSubscription
  TenantSubscription --> Plan
  Plan "1" *-- "many" Feature
  TenantMembership --> Role
  TenantMembership --> User
  FeatureFlag "1" *-- "many" TenantFeatureOverride
  TenantFeatureOverride --> Tenant
  AuditLog --> Tenant
  ImpersonationSession --> Tenant
}

' ============================================================
' PACKAGE: STRATEGY PATTERN - ADMIN OPERATIONS
' ============================================================
package "Strategy Pattern - Admin Operations" #FFF8E1 {

  class AdminOperationContext {
    - strategy: AdminOperationStrategy
    - admin: ServiceAdmin
    --
    + setStrategy(s: AdminOperationStrategy): void
    + executeOperation(request: AdminRequest): void
    + canExecute(request: AdminRequest): Boolean
  }

  interface AdminOperationStrategy {
    + execute(context: AdminOperationContext): void
    + canExecute(admin: ServiceAdmin): Boolean
  }

  class SuperAdminStrategy {
    + execute(context: AdminOperationContext): void
    + canExecute(admin: ServiceAdmin): Boolean
  }

  class SupportAdminStrategy {
    + execute(context: AdminOperationContext): void
    + canExecute(admin: ServiceAdmin): Boolean
  }

  class BillingAdminStrategy {
    + execute(context: AdminOperationContext): void
    + canExecute(admin: ServiceAdmin): Boolean
  }

  AdminOperationContext --> AdminOperationStrategy
  AdminOperationContext --> ServiceAdmin
  SuperAdminStrategy ..|> AdminOperationStrategy
  SupportAdminStrategy ..|> AdminOperationStrategy
  BillingAdminStrategy ..|> AdminOperationStrategy
}

' ============================================================
' PACKAGE: COMMAND PATTERN
' ============================================================
package "Command Pattern" #E3F2FD {

  class AdminCommandInvoker {
    - history: List<AdminCommand>
    - pendingQueue: Queue<AdminCommand>
    --
    + executeCommand(cmd: AdminCommand): void
    + undoLast(): void
    + getHistory(): List<AdminCommand>
    + clearHistory(): void
  }

  interface AdminCommand {
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class AuditEntry {
    - commandName: String
    - adminId: UUID
    - parameters: Map<String, Object>
    - executedAt: DateTime
    - result: String
    --
    + toLog(): AuditLog
  }

  class SuspendTenantCommand {
    - tenantId: UUID
    - reason: String
    - receiver: TenantService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class CreateTenantCommand {
    - tenantName: String
    - planId: UUID
    - receiver: TenantService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class DeleteTenantCommand {
    - tenantId: UUID
    - receiver: TenantService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class AssignPlanCommand {
    - tenantId: UUID
    - planId: UUID
    - previousPlanId: UUID
    - receiver: BillingService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class RevokePlanCommand {
    - tenantId: UUID
    - receiver: BillingService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class EnableFeatureCommand {
    - tenantId: UUID
    - flagId: UUID
    - receiver: FeatureFlagService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class RolloutFeatureGloballyCommand {
    - flagId: UUID
    - receiver: FeatureFlagService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class SendPlatformNotificationCommand {
    - message: String
    - scope: NotificationScope
    - receiver: NotificationService
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  AdminCommandInvoker "1" o-- "many" AdminCommand
  SuspendTenantCommand ..|> AdminCommand
  CreateTenantCommand ..|> AdminCommand
  DeleteTenantCommand ..|> AdminCommand
  AssignPlanCommand ..|> AdminCommand
  RevokePlanCommand ..|> AdminCommand
  EnableFeatureCommand ..|> AdminCommand
  RolloutFeatureGloballyCommand ..|> AdminCommand
  SendPlatformNotificationCommand ..|> AdminCommand
  AdminCommand --> AuditEntry
}

' ============================================================
' PACKAGE: RECEIVER LAYER - ADMIN SERVICES
' ============================================================
package "Receiver Layer - Admin Services" #FCE4EC {

  class TenantService {
    --
    + createTenant(name, planId): Tenant
    + suspendTenant(tenantId): void
    + reactivateTenant(tenantId): void
    + deleteTenant(tenantId): void
    + getTenant(tenantId): Tenant
    + listTenants(): List<Tenant>
  }

  class BillingService {
    --
    + assignPlan(tenantId, planId): void
    + revokePlan(tenantId): void
    + createPlan(details): Plan
    + updatePlan(planId, details): Plan
    + getInvoices(tenantId): List<Invoice>
    + updatePaymentMethod(tenantId, details): void
  }

  class FeatureFlagService {
    --
    + createFlag(name, config): FeatureFlag
    + enableFeature(tenantId, flagId): void
    + disableFeature(tenantId, flagId): void
    + rolloutGlobally(flagId): void
    + getFlags(): List<FeatureFlag>
  }

  class NotificationService {
    --
    + sendPlatformNotification(msg, scope): void
    + sendTenantNotification(tenantId, msg): void
    + getNotifications(tenantId): List<Notification>
  }

  class AuditService {
    --
    + log(entry: AuditEntry): void
    + getLogsForTenant(tenantId): List<AuditLog>
    + getAllLogs(filters): List<AuditLog>
    + exportLogs(dateRange): Report
  }

  SuspendTenantCommand --> TenantService
  CreateTenantCommand --> TenantService
  DeleteTenantCommand --> TenantService
  AssignPlanCommand --> BillingService
  RevokePlanCommand --> BillingService
  EnableFeatureCommand --> FeatureFlagService
  RolloutFeatureGloballyCommand --> FeatureFlagService
  SendPlatformNotificationCommand --> NotificationService
}

' ============================================================
' PACKAGE: FACADE PATTERN
' ============================================================
package "Facade Pattern" #F3E5F5 {

  interface IAdminFacade {
    + manageTenant(action, tenantId): void
    + manageBilling(action, tenantId): void
    + manageFeatures(action, flagId): void
    + monitorSystem(): SystemHealthReport
    + sendNotification(msg, scope): void
  }

  class AdminFacade {
    - tenantService: TenantService
    - billingService: BillingService
    - featureFlagService: FeatureFlagService
    - notificationService: NotificationService
    - auditService: AuditService
    --
    + manageTenant(action, tenantId): void
    + manageBilling(action, tenantId): void
    + manageFeatures(action, flagId): void
    + monitorSystem(): SystemHealthReport
    + sendNotification(msg, scope): void
  }

  AdminFacade ..|> IAdminFacade
  AdminFacade --> TenantService
  AdminFacade --> BillingService
  AdminFacade --> FeatureFlagService
  AdminFacade --> NotificationService
  AdminFacade --> AuditService
}

' ============================================================
' PACKAGE: DECORATOR PATTERN - ADMIN LAYER
' ============================================================
package "Decorator Pattern - Admin Layer" #E0F7FA {

  abstract class BaseCommandDecorator {
    # wrappedCommand: AdminCommand
    --
    + execute(): void
    + undo(): void
    + getAuditEntry(): AuditEntry
  }

  class AuditCommandDecorator {
    - auditService: AuditService
    --
    + execute(): void
    + undo(): void
  }

  class PermissionCheckDecorator {
    - admin: ServiceAdmin
    --
    + execute(): void
    + undo(): void
  }

  class RateLimitDecorator {
    - maxRequests: int
    - windowSeconds: int
    --
    + execute(): void
    + undo(): void
  }

  abstract class AdminFacadeDecorator {
    # wrapped: IAdminFacade
    --
    + manageTenant(action, tenantId): void
    + manageBilling(action, tenantId): void
    + manageFeatures(action, flagId): void
  }

  class MFAVerificationDecorator {
    - admin: ServiceAdmin
    --
    + manageTenant(action, tenantId): void
    + manageBilling(action, tenantId): void
    + manageFeatures(action, flagId): void
  }

  class LoggingFacadeDecorator {
    --
    + manageTenant(action, tenantId): void
    + manageBilling(action, tenantId): void
    + manageFeatures(action, flagId): void
  }

  abstract class StrategyDecorator {
    # wrapped: AdminOperationStrategy
    --
    + execute(context: AdminOperationContext): void
    + canExecute(admin: ServiceAdmin): Boolean
  }

  class AuditStrategyDecorator {
    - auditService: AuditService
    --
    + execute(context: AdminOperationContext): void
    + canExecute(admin: ServiceAdmin): Boolean
  }

  class ValidationStrategyDecorator {
    --
    + execute(context: AdminOperationContext): void
    + canExecute(admin: ServiceAdmin): Boolean
  }

  BaseCommandDecorator ..|> AdminCommand
  BaseCommandDecorator o--> AdminCommand
  AuditCommandDecorator --|> BaseCommandDecorator
  PermissionCheckDecorator --|> BaseCommandDecorator
  RateLimitDecorator --|> BaseCommandDecorator

  AdminFacadeDecorator ..|> IAdminFacade
  AdminFacadeDecorator o--> IAdminFacade
  MFAVerificationDecorator --|> AdminFacadeDecorator
  LoggingFacadeDecorator --|> AdminFacadeDecorator

  StrategyDecorator ..|> AdminOperationStrategy
  StrategyDecorator o--> AdminOperationStrategy
  AuditStrategyDecorator --|> StrategyDecorator
  ValidationStrategyDecorator --|> StrategyDecorator
}

' ============================================================
' PACKAGE: CHAIN OF RESPONSIBILITY
' ============================================================
package "Chain of Responsibility" #FFF3E0 {

  abstract class AdminRequestHandler {
    # next: AdminRequestHandler
    --
    + setNext(handler: AdminRequestHandler): void
    + handle(request: AdminRequest): void
  }

  class AdminRequest {
    - admin: ServiceAdmin
    - commandType: String
    - parameters: Map<String, Object>
    - requestedAt: DateTime
    --
    + getAdmin(): ServiceAdmin
    + getCommandType(): String
  }

  class AuthCheckHandler {
    --
    + handle(request: AdminRequest): void
  }

  class PermissionHandler {
    --
    + handle(request: AdminRequest): void
  }

  class MFACheckHandler {
    --
    + handle(request: AdminRequest): void
  }

  class ExecuteOperationHandler {
    - invoker: AdminCommandInvoker
    --
    + handle(request: AdminRequest): void
  }

  AuthCheckHandler --|> AdminRequestHandler
  PermissionHandler --|> AdminRequestHandler
  MFACheckHandler --|> AdminRequestHandler
  ExecuteOperationHandler --|> AdminRequestHandler
  AdminRequestHandler --> AdminRequestHandler : next
  ExecuteOperationHandler --> AdminCommandInvoker
  AdminRequest --> ServiceAdmin
}

' ============================================================
' ============================================================
' SECTION 2: IDOL DOMAIN LAYER
' ============================================================
' ============================================================

' ============================================================
' PACKAGE: IDOL PROFILE DOMAIN
' ============================================================
package "Idol Profile Domain" #F9FBE7 {

  class IdolProfile {
    - id: UUID
    - tenantId: UUID
    - stageName: String
    - realName: String
    - debutDate: Date
    - agency: String
    - nationality: String
    - profileImageUrl: String
    - bannerImageUrl: String
    - bio: String
    - status: IdolStatus
    --
    + getStageName(): String
    + getSocialLinks(): List<SocialLink>
    + isActive(): Boolean
  }

  class IdolGroup {
    - id: UUID
    - tenantId: UUID
    - groupName: String
    - debutDate: Date
    - agency: String
    - profileImageUrl: String
    - bio: String
    --
    + getMembers(): List<IdolProfile>
    + addMember(idol): void
    + removeMember(idolId): void
  }

  class SocialLink {
    - id: UUID
    - idolId: UUID
    - platform: SocialPlatform
    - url: String
    - followerCount: Long
    - lastSyncedAt: DateTime
    --
    + sync(): void
    + getFollowerCount(): Long
  }

  enum IdolStatus {
    ACTIVE
    HIATUS
    RETIRED
  }

  enum SocialPlatform {
    TWITTER
    INSTAGRAM
    YOUTUBE
    TIKTOK
    WEIBO
  }

  IdolProfile --> IdolStatus
  IdolProfile "1" *-- "many" SocialLink
  SocialLink --> SocialPlatform
  IdolGroup "1" o-- "many" IdolProfile
  IdolProfile --> Tenant
  IdolGroup --> Tenant
}

' ============================================================
' PACKAGE: BLOG DOMAIN
' ============================================================
package "Blog Domain" #FFF9C4 {

  class BlogPost {
    - id: UUID
    - tenantId: UUID
    - authorId: UUID
    - title: String
    - content: String
    - coverImageUrl: String
    - tags: List<String>
    - status: PostStatus
    - visibility: Visibility
    - publishedAt: DateTime
    - createdAt: DateTime
    - updatedAt: DateTime
    --
    + publish(): void
    + archive(): void
    + isAccessibleBy(fan): Boolean
  }

  class BlogCategory {
    - id: UUID
    - tenantId: UUID
    - name: String
    --
    + getPosts(): List<BlogPost>
  }

  class BlogComment {
    - id: UUID
    - postId: UUID
    - fanId: UUID
    - content: String
    - createdAt: DateTime
    - isHidden: Boolean
    --
    + hide(): void
    + getAuthor(): Fan
  }

  class BlogLike {
    - id: UUID
    - postId: UUID
    - fanId: UUID
    - likedAt: DateTime
  }

  enum PostStatus {
    DRAFT
    PUBLISHED
    ARCHIVED
  }

  enum Visibility {
    PUBLIC
    SUBSCRIBERS_ONLY
    PAID_ONLY
  }

  BlogPost --> PostStatus
  BlogPost --> Visibility
  BlogPost --> BlogCategory
  BlogPost "1" *-- "many" BlogComment
  BlogPost "1" *-- "many" BlogLike
  BlogPost --> Tenant
}

' ============================================================
' PACKAGE: FAN & MEMBERSHIP DOMAIN
' ============================================================
package "Fan and Membership Domain" #E8F5E9 {

  class Fan {
    - id: UUID
    - tenantId: UUID
    - email: String
    - username: String
    - passwordHash: String
    - displayName: String
    - avatarUrl: String
    - createdAt: DateTime
    - isActive: Boolean
    --
    + getId(): UUID
    + getEmail(): String
    + getActiveSubscription(): FanSubscription
  }

  class FanSubscription {
    - id: UUID
    - fanId: UUID
    - tenantId: UUID
    - tierId: UUID
    - startDate: DateTime
    - endDate: DateTime
    - status: FanSubscriptionStatus
    - autoRenew: Boolean
    --
    + isActive(): Boolean
    + renew(): void
    + cancel(): void
    + getState(): SubscriptionState
  }

  class MembershipTier {
    - id: UUID
    - tenantId: UUID
    - name: String
    - price: Decimal
    - billingCycle: BillingCycle
    - maxMembers: Integer
    --
    + getPerks(): List<TierPerk>
    + hasAvailableSlots(): Boolean
  }

  class TierPerk {
    - id: UUID
    - tierId: UUID
    - description: String
    - type: PerkType
    --
    + getType(): PerkType
  }

  enum FanSubscriptionStatus {
    ACTIVE
    EXPIRING
    EXPIRED
    CANCELLED
  }

  enum PerkType {
    EXCLUSIVE_CONTENT
    EARLY_ACCESS
    MERCH_DISCOUNT
    LIVE_ACCESS
    BADGE
  }

  Fan --> Tenant
  Fan "1" *-- "many" FanSubscription
  FanSubscription --> MembershipTier
  MembershipTier "1" *-- "many" TierPerk
  TierPerk --> PerkType
  FanSubscription --> FanSubscriptionStatus
  MembershipTier --> Tenant
}

