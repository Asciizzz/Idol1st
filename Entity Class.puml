' ============================================================
' PACKAGE: MERCH DOMAIN
' ============================================================
package "Merch Domain" #FCE4EC {

  class MerchProduct {
    - id: UUID
    - tenantId: UUID
    - name: String
    - description: String
    - price: Decimal
    - currency: String
    - coverImageUrl: String
    - images: List<String>
