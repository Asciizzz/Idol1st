				},
				"type": "JS_EVENT",
				"name": "Card Flip",
				"event": "click",
				"code": "\nconst target = event.currentTarget;\ntarget.style.transform = 'rotateY(180deg) scale(1.05)';\nsetTimeout(() => {\n  target.style.transform = 'rotateY(0deg) scale(1)';\n}, 800);\n"
			}
		},
