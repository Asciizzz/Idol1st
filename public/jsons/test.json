				"name": "Theme Toggle",
				"event": "click",
				"code": "\ndocument.body.classList.toggle('light-theme');\nevent.currentTarget.innerText = document.body.classList.contains('light-theme') ? 'Dark Mode' : 'Light Mode';\n"
			}
