				"type": "JS_EVENT",
				"name": "Parallax Leave",
				"event": "mouseleave",
				"code": "\nconst inner = event.currentTarget.querySelector('.parallax-inner');\nif(inner) inner.style.transform = 'translate(0, 0) scale(1)';\n"
			}
